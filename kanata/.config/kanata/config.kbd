  _       _       @m3     f10                                     _       _                       _       _       _       _               _
)

(deflayer mod_ctrl
  esc     f1      f2      f3      f4      f5      f6      f7      f8      f9      f10     f11     f12     ins     prtsc   del     home    end     pgup    pgdn
  grv     1       2       3       4       5       6       7       8       9       0       -       =       bspc            nlck    kp/     kp*     kp-
  tab     q       w       e       r       t       y       u       i       o       p       [       ]       \               kp7     kp8     kp9     kp+
  _       a       s       d       f       g       h       j       k       l       ;       '       ret                     kp4     kp5     kp6     kprt
  lsft    z       x       c       v       b       n       m       ,       .       /       rsft            up              kp1     kp2     kp3 
  lctl    lmet    lalt    lsft                                      ralt    _                     left    down    rght    kp0             kp.
)

(deflayer mod_win
  esc     f1      f2      f3      f4      f5      f6      f7      f8      f9      f10     f11     f12     ins     prtsc   del     home    end     pgup    pgdn
  grv     1       2       3       4       5       6       7       8       9       0       -       =       bspc            nlck    kp/     kp*     kp-
  tab     q       w       e       r       t       y       u       i       o       p       [       ]       \               kp7     kp8     kp9     kp+
  _       a       s       d       f       g       h       j       k       l       ;       '       ret                     kp4     kp5     kp6     kprt
  lsft    z       x       c       v       b       n       m       ,       .       /       rsft            up              kp1     kp2     kp3 
  lctl    lmet    lalt    @win                                    ralt    _                     left    down    rght    kp0             kp.
)

(deflayer mod_alt
  esc     f1      f2      f3      f4      f5      f6      f7      f8      f9      f10     f11     f12     ins     prtsc   del     home    end     pgup    pgdn
  grv     1       2       3       4       5       6       7       8       9       0       -       =       bspc            nlck    kp/     kp*     kp-
  tab     q       w       e       r       t       y       u       i       o       p       [       ]       \               kp7     kp8     kp9     kp+
  _       a       s       d       f       g       h       j       k       l       ;       '       ret                     kp4     kp5     kp6     kprt
  lsft    z       x       c       v       b       n       m       ,       .       /       rsft            up              kp1     kp2     kp3 
  lctl    lmet    @alt    lsft                                    @ctl    _                       left    down    rght    kp0             kp.
)

(deflayer mod_shit
  _       _       _       _       _       _       _       _       _       _       _       _       _       _       _       _       _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _       _       _               _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _       _       _               _       _       _       _
  _       @m3     @m2     _       _       _       _       _       _       _       _       _       _                       _       _       _       _
  _       _       _       _       _       _       _       _       _       _       _       _               _               _       _       _ 
  _       _       _       @alt                                    @ctl    _                       _       _       _       _               _
)

(defalias
  m2 (multi (release-key lsft) (release-key lmet) (layer-toggle mod_active2))
  m3 (layer-toggle mod_active3)
  mod_shit (layer-toggle mod_shit) 
  nvtg (one-shot-press 1000 (layer-toggle mod_nvim))
  nvsw (layer-switch mod_nvim) 
  colosw (layer-switch colemak-dh)
  colotg (layer-toggle colemak-dh)
  num (layer-switch mod_num)
  switch (layer-toggle mod_switch)
  mdfnu (layer-switch modifiernum) 
  numsh (layer-switch modifiernumshiftholder)
  f1-12 (layer-switch mod_f1-12)
  coleff (layer-switch colemak-dh-ff)
)

(defalias
  osl_sw (one-shot-press 1000 (layer-toggle mod_switch))
  osl_he (one-shot-press 1000 (layer-toggle homend))
  CHE (one-shot-press 1000 (layer-toggle ctrlhomend))
  osl_md (one-shot-press 1000 (layer-toggle modifier))
  sropt (one-shot-press 1000 (layer-toggle search-opt))
  mdfns (multi (one-shot 1000 lsft) (one-shot-press 1000 (layer-toggle modifiernumshift)))
 
)

(defalias
  del_w (macro d w)
  ins (macro ins ins)
  osl_d (multi bspc (one-shot 1000 (layer-toggle nvim_delete)))
  tabe (multi (layer-switch mod_nvim) esc)
  taba (multi (layer-switch colemak-dh) a)
  tabi (multi (layer-switch colemak-dh) i)
  fd (multi f (one-shot-press 1000 (layer-toggle colemak-dh-f)))
  fs (multi lsft f (one-shot-press 1000 (layer-toggle colemak-dh-f)))
  t1 (multi t (one-shot-press 1000 (layer-toggle colemak-dh-f)))
  tabii (multi (layer-switch colemak-dh) S-r)
  shi (multi (one-shot 1000 lsft) (one-shot-press 1000 (layer-toggle mod_shift)))
  ctl (multi lctl (layer-toggle mod_ctrl))
  win (multi lmet (layer-toggle mod_win))
  alt (multi lalt (layer-toggle mod_alt))
  srchf (multi lctl f (layer-switch colemak-dh-search)) 
  sups (multi (one-shot 1000 lsft) (one-shot-press 1000 (layer-toggle pre-next-back)))
  entnb (multi (unmod ent) (layer-switch next-back))
  sent (multi (one-shot 1000 lsft) (one-shot-press 1000 (layer-toggle shiftent)))
  cmd (multi lsft ; (layer-switch colemak-dh-cmd))
  scmd (multi (one-shot 1000 lsft) (one-shot-press 1000 (layer-toggle pre-cmd)))
  cmdf (multi (unmod ent) (layer-switch cmd-function))
)

(defalias
  ss (one-shot 1000 lsft) ;; Sticky Shift
  ;; sc (one-shot 2000 lctl) ;; Sticky Ctrl
  ;; sa (one-shot 2000 lalt) ;; Sticky Alt
  ;; sw (one-shot 2000 lmet) ;; Sticky Win (Super)
)

(defalias
  larr (multi left (one-shot-press 1000 (layer-toggle pre-left-arrow)))
  larrb (multi left (one-shot-press 1000 (layer-toggle pre-left-arrow)))
  rght (multi rght (one-shot-press 1000 (layer-toggle pre-right-arrow)))
  s-nav (tap-hold-press 200 200 left (layer-toggle pre-left-arrow))
  pla2 (multi left (one-shot-press 1000 (layer-toggle pre-left-arrow2))) 
  pra2 (layer-switch pre-right-arrow2)
  larrm (layer-switch left-arrow)
)

(defalias
  numc (multi (release-key lsft) (one-shot 1000 lctl) (one-shot-press 1000 (layer-toggle mod_num))) 
  nums (multi (release-key lsft) (one-shot 1000 lsft) (one-shot-press 1000 (layer-toggle mod_num)))
  numa (multi (release-key lsft) (one-shot 1000 lalt) (one-shot-press 1000 (layer-toggle mod_num)))
  numw (multi (release-key lsft) (one-shot 1000 lmet) (one-shot-press 1000 (layer-toggle mod_num)))
)

(defalias
  viw (macro v i w)
  cgn (macro c g n)
)

(defalias
  ;; Tổ hợp: Win (meta) + Alt + Shift + Mũi tên
  wasl (multi lmet lalt lsft left)
  wasr (multi lmet lalt lsft rght)
  wasu (multi lmet lalt lsft up)
  wasd (multi lmet lalt lsft down)

  ;; Tổ hợp: Win (meta) + Alt + Shift + Mũi tên
  swwas (layer-switch createwindows)
  wwasl (multi lctl lmet lalt lsft left)
  wwasr (multi lctl lmet lalt lsft rght)
  wwasu (multi lctl lmet lalt lsft up)
  wwasd (multi lctl lmet lalt lsft down)
  onl (multi lctl lmet lalt lsft o)
  hold (multi lctl lmet lalt lsft)
  test (macro left down rght up)
)

(defalias
  m1 (multi lctl lmet lalt lsft m) ;; @onl (only)
  x1 (multi lctl lmet lalt lsft x) ;; @cls (close)
  =1 (multi lctl lmet lalt lsft =) ;; @equ (equalize)
  r1 (multi lctl lmet lalt lsft r) ;; @rot (rotate)
)

