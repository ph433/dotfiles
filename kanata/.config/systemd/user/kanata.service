[Unit]
Description=Kanata Keyboard Service (User Mode)
# Link từ điển mã phím để tra cứu nhanh khi gõ status
Documentation=https://github.com/jtroo/kanata/blob/main/parser/src/keys/mod.rs

[Service]
ExecStart=%h/dotfiles/bin/kanata --cfg %h/.config/kanata/config.kbd --no-wait
Restart=on-failure
RestartSec=3
ExecStartPost=/usr/bin/sh -c 'sleep 1 && . /etc/default/keyboard && /usr/bin/setxkbmap -layout "$XKBLAYOUT" -variant "$XKBVARIANT" -option "$XKBOPTIONS"'
[Install]
WantedBy=default.target